# Cairn — local development environment
# Copy to .env.local and fill in your Supabase project credentials.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Web Push — generate with `npx web-push generate-vapid-keys`
# The public key goes here; the private key goes to your Supabase Edge Function.
VITE_VAPID_PUBLIC_KEY=

# Map tiles + reverse geocoding + address autocomplete
VITE_MAPBOX_ACCESS_TOKEN=

# Optional integrations (Phase 2+)
# VITE_STRIPE_PUBLISHABLE_KEY=
# VITE_POSTHOG_KEY=
